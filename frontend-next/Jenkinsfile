pipeline {
  agent any

  tools {
    nodejs 'NodeJS 22'
  }

  environment {
    CI = 'true'
  }

  stages {
    stage('Install') {
      steps {
        dir('frontend-next') {
          sh 'npm install --global pnpm@10.33.0'
          sh 'pnpm install --frozen-lockfile'
        }
      }
    }

    stage('Test') {
      steps {
        sh 'echo "No tests yet"'
      }
    }

    stage('SonarQube Analysis') {
      steps {
        dir('frontend-next') {
          withSonarQubeEnv('sonarqube-local') {
            sh "${tool 'SonarScanner'}/bin/sonar-scanner"
          }
        }
      }
    }

    stage('Quality Gate') {
      steps {
        timeout(time: 5, unit: 'MINUTES') {
          waitForQualityGate abortPipeline: true
        }
      }
    }

    stage('Build') {
      steps {
        dir('frontend-next') {
          sh 'pnpm build'
        }
      }
    }
  }
}
